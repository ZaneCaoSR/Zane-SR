# 微信小程序配置（在微信公众平台获取）
WECHAT_APP_ID=YOUR_WECHAT_APP_ID
WECHAT_APP_SECRET=YOUR_WECHAT_APP_SECRET
WECHAT_TEMPLATE_ID=YOUR_SUBSCRIBE_MESSAGE_TEMPLATE_ID

# 和风天气 API Key（在 dev.qweather.com 申请）
QWEATHER_API_KEY=YOUR_QWEATHER_API_KEY

# 推送时间（24小时制，默认早8点）
PUSH_HOUR=8
PUSH_MINUTE=0

# 数据库路径
DATABASE_PATH=/root/projects/weather-mini/data/weather.db
