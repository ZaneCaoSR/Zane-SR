/* app.wxss - 奶油日记风格设计系统 */

page {
  /* 主色调 - 温暖奶油系 */
  --color-bg: #FFFDF7;
  --color-bg-secondary: #FFF8F0;
  --color-surface: #FFFFFF;
  --color-surface-elevated: #FFFFFF;

  /* 强调色 - 温暖杏色 */
  --color-accent: #E8A87C;
  --color-accent-light: #FFCDB2;
  --color-accent-dark: #C38D6B;

  /* 文字色 */
  --color-text-primary: #4A403A;
  --color-text-secondary: #8B7E74;
  --color-text-tertiary: #B8AFA4;
  --color-text-inverse: #FFFFFF;

  /* 功能色 */
  --color-success: #95B8A0;
  --color-warning: #E8C07D;
  --color-error: #D4847C;

  /* 天气色 */
  --color-sunny: #FFD166;
  --color-cloudy: #A8C0D8;
  --color-rainy: #7BA3C9;
  --color-snowy: #E8EEF2;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(74, 64, 58, 0.06);
  --shadow-md: 0 8rpx 24rpx rgba(74, 64, 58, 0.1);
  --shadow-lg: 0 16rpx 48rpx rgba(74, 64, 58, 0.14);
  --shadow-float: 0 24rpx 60rpx rgba(74, 64, 58, 0.18);

  /* 圆角 */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-full: 9999rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* 字体 */
  --font-family-display: 'Didot', 'Bodoni MT', 'STSong', serif;
  --font-family-body: -apple-system, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;

  /* 动画 */
  --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-out-back: cubic-bezier(0.34, 1.56, 0.64, 1);
  --duration-fast: 0.2s;
  --duration-normal: 0.35s;
  --duration-slow: 0.5s;

  background-color: var(--color-bg);
  font-family: var(--font-family-body);
  color: var(--color-text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.container {
  min-height: 100vh;
  padding: var(--spacing-md);
}

/* 卡片组件 */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: var(--spacing-md);
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all var(--duration-normal) var(--ease-out-expo);
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: var(--color-text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(232, 168, 124, 0.4);
}

.btn-secondary {
  background: var(--color-surface);
  color: var(--color-accent);
  border: 2rpx solid var(--color-accent);
}

.btn-ghost {
  background: transparent;
  color: var(--color-text-secondary);
}

/* 输入框 */
.input {
  width: 100%;
  padding: 24rpx 32rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  font-size: 28rpx;
  color: var(--color-text-primary);
  transition: all var(--duration-normal);
}

.input:focus {
  background: var(--color-surface);
  border-color: var(--color-accent);
  box-shadow: 0 0 0 8rpx rgba(232, 168, 124, 0.15);
}

.input::placeholder {
  color: var(--color-text-tertiary);
}

/* 标题 */
.title {
  font-family: var(--font-family-display);
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: -0.5rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--color-text-tertiary), transparent);
  opacity: 0.3;
  margin: var(--spacing-md) 0;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 加载动画 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-bg-secondary);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 淡入动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn var(--duration-normal) var(--ease-out-expo) forwards;
}

/* 弹跳动画 */
@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.8);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.bounce-in {
  animation: bounceIn var(--duration-normal) var(--ease-out-back) forwards;
}

/* 页面进入动画 */
.page-enter {
  animation: pageEnter var(--duration-slow) var(--ease-out-expo) forwards;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-md);
}

.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.6;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  text-align: center;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
