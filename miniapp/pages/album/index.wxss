/* 相册首页样式 */

.album-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F8 0%, #FFF0F5 100%);
  padding-bottom: 180rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.settings-btn {
  padding: 10rpx;
}

.settings-btn .iconfont {
  font-size: 40rpx;
}

/* 月份时间线 */
.month-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 30rpx 0;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
}

.month-list {
  display: inline-flex;
  padding: 0 30rpx;
  gap: 24rpx;
}

.month-card {
  position: relative;
  width: 200rpx;
  height: 240rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f8f8f8;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.month-card.active {
  transform: scale(1.05);
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 157, 0.3);
}

.month-label {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  z-index: 2;
}

.photo-count {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  z-index: 2;
}

.cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.empty-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  background: linear-gradient(135deg, #FFE4EC 0%, #FFD4E5 100%);
}

/* 照片网格 */
.photo-grid-scroll {
  height: calc(100vh - 400rpx);
}

.section-title {
  padding: 30rpx 40rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 30rpx;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-tags {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
}

.tag {
  font-size: 18rpx;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  color: #fff;
}

.tag.expression {
  background: rgba(255, 107, 157, 0.8);
}

/* 空状态 */
.empty-month {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.empty-global {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-actions {
  display: flex;
  gap: 30rpx;
  margin-top: 40rpx;
}

.primary-btn,
.secondary-btn {
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
  color: #fff;
}

.secondary-btn {
  background: #fff;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
}

.upload-btn {
  margin-top: 20rpx;
  padding: 20rpx 50rpx;
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #FF6B9D;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 悬浮按钮 */
.fab-container {
  position: fixed;
  right: 30rpx;
  bottom: 100rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}

.fab-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 157, 0.4);
}

.fab-btn.camera {
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
}

.fab-btn.album {
  background: linear-gradient(135deg, #67D4CA 0%, #4ECDC4 100%);
  font-size: 44rpx;
}
