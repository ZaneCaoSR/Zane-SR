/* 相册首页样式 - 奶油日记风格 */

.album-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 200rpx;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(180deg, #FFF8F0 0%, var(--color-bg) 100%);
  padding: var(--spacing-lg) var(--spacing-md);
  padding-top: var(--spacing-xl);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.title-group {
  display: flex;
  flex-direction: column;
}

.title {
  font-family: var(--font-family-display);
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: -1rpx;
  margin-bottom: var(--spacing-xs);
}

.subtitle {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.header-actions {
  display: flex;
  gap: var(--spacing-sm);
}

.action-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  font-size: 36rpx;
  transition: all var(--duration-normal) var(--ease-out-expo);
}

.action-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-sm);
}

/* 月份时间线 */
.month-section {
  padding: var(--spacing-md);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-family: var(--font-family-display);
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.month-scroll {
  width: 100%;
  white-space: nowrap;
}

.month-list {
  display: inline-flex;
  gap: var(--spacing-md);
  padding: var(--spacing-xs) 0;
}

.month-card {
  position: relative;
  width: 220rpx;
  height: 280rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-surface);
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal) var(--ease-out-expo);
}

.month-card.active {
  transform: scale(1.03);
  box-shadow: var(--shadow-lg);
}

.month-card:active {
  transform: scale(0.98);
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.cover-img {
  width: 100%;
  height: 100%;
  transition: transform var(--duration-slow);
}

.month-card.active .cover-img {
  transform: scale(1.05);
}

.cover-overlay {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-accent-light) 100%);
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.6;
}

.card-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md);
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.month-label {
  display: block;
  font-family: var(--font-family-display);
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.photo-count {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.card-badge {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  padding: 6rpx 16rpx;
  background: var(--color-accent);
  border-radius: var(--radius-full);
  font-size: 20rpx;
  color: #fff;
  box-shadow: var(--shadow-sm);
}

/* 照片区域 */
.photo-section {
  padding: var(--spacing-md);
}

.photo-grid-scroll {
  height: calc(100vh - 580rpx);
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-sm);
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-bg-secondary);
  animation: fadeIn var(--duration-normal) var(--ease-out-expo) forwards;
  opacity: 0;
}

.photo-img {
  width: 100%;
  height: 100%;
  transition: transform var(--duration-slow);
}

.photo-item:active .photo-img {
  transform: scale(1.05);
}

.photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-xs) var(--spacing-sm);
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.4));
  opacity: 0;
  transition: opacity var(--duration-normal);
}

.photo-item:active .photo-overlay {
  opacity: 1;
}

.photo-date {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
}

.photo-tags {
  position: absolute;
  top: var(--spacing-xs);
  left: var(--spacing-xs);
  right: var(--spacing-xs);
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: var(--radius-full);
  font-size: 18rpx;
  color: var(--color-text-primary);
  box-shadow: var(--shadow-sm);
}

/* 空状态 */
.empty-month {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-md);
}

.empty-illustration {
  font-size: 96rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-global {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacing-lg);
}

.empty-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.empty-emoji {
  font-size: 160rpx;
  line-height: 1;
  margin-bottom: var(--spacing-md);
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}

.empty-decoration {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.deco-line {
  width: 40rpx;
  height: 4rpx;
  background: var(--color-accent);
  border-radius: 2rpx;
  opacity: 0.4;
}

.deco-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--color-accent);
  border-radius: 50%;
}

.empty-title {
  font-family: var(--font-family-display);
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.empty-description {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  margin-bottom: var(--spacing-xl);
}

.empty-actions {
  display: flex;
  gap: var(--spacing-md);
}

.btn-large {
  padding: 28rpx 64rpx;
  font-size: 32rpx;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
  color: var(--color-text-tertiary);
}

/* 悬浮按钮 */
.fab-container {
  position: fixed;
  right: var(--spacing-lg);
  bottom: 120rpx;
  z-index: 100;
}

.fab-btn {
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  border-radius: 50%;
  box-shadow: var(--shadow-float);
  transition: all var(--duration-normal) var(--ease-out-expo);
}

.fab-btn:active {
  transform: scale(0.9);
}

.fab-icon {
  font-size: 56rpx;
  font-weight: 300;
  color: #fff;
  line-height: 1;
}
