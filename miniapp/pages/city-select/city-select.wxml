<!--
  city-select.wxml - 城市选择页面
  功能：搜索并选择城市，可添加到订阅列表
-->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-box">
    <input
      class="search-input"
      value="{{searchKey}}"
      placeholder="搜索城市，如：北京、上海"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <icon type="search" size="18" color="#999" wx:if="{{!searchKey}}" />
    <icon type="clear" size="18" color="#999" wx:else bindtap="onClearSearch" />
  </view>

  <!-- 搜索结果 -->
  <view class="search-result" wx:if="{{searchResult}}">
    <view class="result-header">搜索结果</view>
    <view 
      class="result-item" 
      wx:for="{{searchResult}}" 
      wx:key="id"
      bindtap="onSelectCity"
      data-city="{{item}}"
    >
      <text class="city-name">{{item.name}}</text>
      <text class="city-province">{{item.province}}</text>
      <button 
        class="add-btn" 
        size="mini" 
        bindtap="onAddToSubscribe"
        data-city="{{item}}"
      >
        + 订阅
      </button>
    </view>
  </view>

  <!-- 热门城市 -->
  <view class="section" wx:if="{{!searchKey && !searchResult}}">
    <view class="section-title">🌡️ 热门城市</view>
    <view class="city-grid">
      <view 
        class="city-tag" 
        wx:for="{{hotCities}}" 
        wx:key="id"
        bindtap="onSelectCity"
        data-city="{{item}}"
      >
        {{item.name}}
      </view>
    </view>
  </view>

  <!-- 常用城市 -->
  <view class="section" wx:if="{{!searchKey && !searchResult && commonCities.length > 0}}">
    <view class="section-title">📌 最近使用</view>
    <view class="city-grid">
      <view 
        class="city-tag" 
        wx:for="{{commonCities}}" 
        wx:key="id"
        bindtap="onSelectCity"
        data-city="{{item}}"
      >
        {{item.name}}
      </view>
    </view>
  </view>

  <!-- 当前订阅的城市 -->
  <view class="section" wx:if="{{!searchKey && !searchResult && subscribedCities.length > 0}}">
    <view class="section-title">🔔 我的订阅</view>
    <view class="subscribed-list">
      <view 
        class="subscribed-item" 
        wx:for="{{subscribedCities}}" 
        wx:key="city"
        bindtap="onSelectCity"
        data-city="{{item}}"
      >
        <view class="subscribed-info">
          <text class="subscribed-city">{{item.city}}</text>
          <text class="subscribed-time">每天 8:00 推送</text>
        </view>
        <view 
          class="remove-btn" 
          catchtap="onRemoveSubscribe"
          data-city="{{item.city}}"
        >
          ✕
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-tip" wx:if="{{searchKey && searchResult.length === 0 && !searchLoading}}">
    <text>未找到匹配的城市 🏙️</text>
    <text class="empty-hint">试试其他城市名</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-tip" wx:if="{{searchLoading}}">
    <text>搜索中...</text>
  </view>
</view>
