/* 城市选择页面样式 - 奶油日记风格 */

.container {
  padding: var(--spacing-md);
  min-height: 100vh;
  background: var(--color-bg);
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background: var(--color-surface);
  border-radius: var(--radius-full);
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-md);
}

.search-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 var(--spacing-sm);
  color: var(--color-text-primary);
}

.search-input::placeholder {
  color: var(--color-text-tertiary);
}

.clear-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* 搜索结果 */
.search-result {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-bg-secondary);
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.result-count {
  font-size: 22rpx;
  color: var(--color-accent);
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-bg-secondary);
  transition: background var(--duration-fast);
}

.result-item:last-child {
  border-bottom: none;
}

.result-item:active {
  background: var(--color-bg-secondary);
}

.result-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.city-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.city-province {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.add-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 12rpx rgba(232, 168, 124, 0.3);
  transition: all var(--duration-normal);
}

.add-btn:active {
  transform: scale(0.95);
}

/* 区块 */
.section {
  margin-bottom: var(--spacing-xl);
}

.section-header {
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-family: var(--font-family-display);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 城市网格 */
.city-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.city-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface);
  padding: 20rpx 36rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal) var(--ease-out-expo);
}

.city-tag:active {
  transform: scale(0.95);
  background: var(--color-accent-light);
}

/* 订阅列表 */
.subscribed-list {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.subscribed-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-bg-secondary);
  transition: background var(--duration-fast);
}

.subscribed-item:last-child {
  border-bottom: none;
}

.subscribed-item:active {
  background: var(--color-bg-secondary);
}

.subscribed-info {
  display: flex;
  flex-direction: column;
}

.subscribed-city-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.subscribed-city {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.subscribed-badge {
  padding: 4rpx 12rpx;
  background: rgba(232, 168, 124, 0.15);
  border-radius: var(--radius-full);
  font-size: 20rpx;
  color: var(--color-accent);
}

.subscribed-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}

.remove-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-secondary);
  border-radius: 50%;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  transition: all var(--duration-normal);
}

.remove-btn:active {
  background: var(--color-error);
  color: #fff;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) 0;
}

.empty-illustration {
  font-size: 96rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-xs);
}

/* 加载中 */
.loading-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
  color: var(--color-text-tertiary);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-bg-secondary);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--spacing-sm);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
