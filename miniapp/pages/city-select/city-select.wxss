/* city-select.wxss - 城市选择页面样式 */

.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #F0F6FF;
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  height: 48rpx;
  line-height: 48rpx;
}

.search-box icon {
  margin-left: 16rpx;
}

/* 搜索结果 */
.search-result {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.result-header {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 30rpx;
  background: #f9f9f9;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.city-name {
  font-size: 32rpx;
  color: #333;
  flex: 1;
}

.city-province {
  font-size: 26rpx;
  color: #999;
  margin-right: 20rpx;
}

.add-btn {
  background: #4A90D9;
  color: #fff;
  font-size: 24rpx;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
}

/* 区块 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: 500;
}

/* 城市网格 */
.city-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.city-tag {
  background: #fff;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 订阅列表 */
.subscribed-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.subscribed-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.subscribed-item:last-child {
  border-bottom: none;
}

.subscribed-info {
  display: flex;
  flex-direction: column;
}

.subscribed-city {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.subscribed-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.remove-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-tip, .loading-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  margin-top: 10rpx;
}
