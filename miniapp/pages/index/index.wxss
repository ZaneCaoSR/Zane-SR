/* index.wxss - 首页样式 */

.container {
  padding: 30rpx;
}

/* 城市输入区域 */
.city-section {
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.city-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.city-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #fff;
  border-radius: 36rpx;
  font-size: 30rpx;
  border: 2rpx solid #D0E4F7;
}

.search-btn {
  background: #4A90D9;
  color: #fff;
  border-radius: 36rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
}

/* 天气卡片 */
.weather-card {
  background: linear-gradient(135deg, #4A90D9, #7EC8E3);
  border-radius: 24rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}

.weather-city {
  font-size: 32rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.weather-temp {
  font-size: 120rpx;
  font-weight: 200;
  line-height: 1;
  margin-bottom: 10rpx;
}

.weather-desc {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.weather-range {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 20rpx;
}

.weather-detail {
  display: flex;
  gap: 30rpx;
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 16rpx;
}

.weather-update {
  font-size: 22rpx;
  opacity: 0.6;
}

/* 加载 & 空状态 */
.loading-box, .empty-box {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 60rpx 0;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: #E8F0F9;
  margin: 30rpx 0;
}

/* 订阅区域 */
.subscribe-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.subscribe-desc {
  font-size: 26rpx;
  color: #888;
  display: block;
  margin: 16rpx 0 30rpx;
  line-height: 1.6;
}

.subscribe-btn {
  width: 100%;
  background: #4A90D9;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.subscribe-hint {
  font-size: 24rpx;
  color: #bbb;
  display: block;
  text-align: center;
  margin-top: 16rpx;
}

/* 已订阅状态 */
.subscribed-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.subscribed-tag {
  font-size: 30rpx;
  color: #4A90D9;
  font-weight: 500;
}

.unsubscribe-btn {
  background: #f5f5f5;
  color: #999;
  border-radius: 30rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
}

/* 快捷入口 */
.quick-entry {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.entry-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.entry-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.entry-text {
  font-size: 26rpx;
  color: #666;
}

/* 查看详情按钮 */
.detail-btn {
  margin-top: 20rpx;
  background: rgba(255,255,255,0.2);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  height: 56rpx;
  line-height: 56rpx;
}
