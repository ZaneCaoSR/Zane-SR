<!-- 我的页面 - 奶油日记风格 -->
<view class="my-container page-enter">
  <!-- 用户信息卡片 -->
  <view class="user-hero">
    <view class="hero-bg" style="background: linear-gradient(135deg, {{themeColor}} 0%, {{themeColorDark}} 100%);">
      <view class="bg-pattern"></view>
    </view>

    <view class="user-card">
      <view class="avatar-wrapper">
        <image
          class="avatar"
          src="{{userInfo.avatarUrl || '/assets/icons/my.png'}}"
          mode="aspectFill"
        />
        <view class="avatar-ring"></view>
      </view>

      <view class="user-info">
        <text class="nickname">{{userInfo.nickName || '点击登录'}}</text>
        <text class="status">{{isLoggedIn ? '欢迎回来' : '登录后享受更多功能'}}</text>
      </view>

      <button
        class="login-btn {{isLoggedIn ? 'logout' : ''}}"
        style="background: linear-gradient(135deg, {{themeColor}} 0%, {{themeColorDark}} 100%);"
        bindtap="{{isLoggedIn ? 'onLogout' : 'onLogin'}}"
      >
        <text class="btn-text">{{isLoggedIn ? '退出' : '登录'}}</text>
      </button>
    </view>
  </view>

  <!-- 宝宝信息卡片 -->
  <view class="baby-card" wx:if="{{babyInfo}}" bindtap="goToSettings">
    <view class="baby-avatar-wrapper">
      <image
        class="baby-avatar"
        src="{{babyInfo.avatar || '/assets/icons/my.png'}}"
        mode="aspectFill"
      />
    </view>
    <view class="baby-info">
      <view class="baby-names">
        <text class="baby-name">{{babyInfo.name}}</text>
        <text class="baby-nickname" wx:if="{{babyInfo.nickname}}">({{babyInfo.nickname}})</text>
      </view>
      <text class="baby-age">{{babyInfo.birthDate ? getBabyAge(babyInfo.birthDate) : '设置宝宝信息'}}</text>
    </view>
    <view class="baby-action">
      <text>编辑</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-card">
      <view class="menu-item" bindtap="onThemeChange">
        <view class="menu-item-left">
          <view class="menu-icon-wrapper">
            <text class="menu-icon">🎨</text>
          </view>
          <view class="menu-text-group">
            <text class="menu-text">主题颜色</text>
            <text class="menu-desc">自定义你的专属配色</text>
          </view>
        </view>
        <view class="menu-item-right">
          <view class="color-preview" style="background: {{themeColor}};"></view>
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="menu-divider"></view>

      <view class="menu-item" bindtap="onAIModelChange">
        <view class="menu-item-left">
          <view class="menu-icon-wrapper">
            <text class="menu-icon">🤖</text>
          </view>
          <view class="menu-text-group">
            <text class="menu-text">AI 模型</text>
            <text class="menu-desc">{{aiModel || 'GPT-4o mini'}}</text>
          </view>
        </view>
        <view class="menu-item-right">
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="menu-divider"></view>

      <view class="menu-item" bindtap="onAbout">
        <view class="menu-item-left">
          <view class="menu-icon-wrapper">
            <text class="menu-icon">ℹ️</text>
          </view>
          <view class="menu-text-group">
            <text class="menu-text">关于我们</text>
            <text class="menu-desc">了解 Zane-SR</text>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>

      <view class="menu-divider"></view>

      <view class="menu-item">
        <view class="menu-item-left">
          <view class="menu-icon-wrapper">
            <text class="menu-icon">📋</text>
          </view>
          <view class="menu-text-group">
            <text class="menu-text">版本信息</text>
            <text class="menu-desc">当前版本 v1.0.0</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="footer-decoration">
    <view class="deco-line"></view>
    <text class="footer-text">Made with ♥</text>
    <view class="deco-line"></view>
  </view>

  <!-- 主题颜色选择弹窗 -->
  <view class="theme-modal" wx:if="{{showThemeModal}}">
    <view class="theme-mask" bindtap="onCloseTheme"></view>
    <view class="theme-content bounce-in">
      <view class="theme-header">
        <text class="theme-title">选择主题颜色</text>
        <text class="theme-subtitle">挑选你喜欢的颜色</text>
      </view>

      <view class="color-grid">
        <block wx:for="{{colorOptions}}" wx:key="index">
          <view
            class="color-option {{themeColor === item.color ? 'active' : ''}}"
            style="background: {{item.color}};"
            bindtap="selectTheme"
            data-color="{{item.color}}"
            data-colordark="{{item.colorDark}}"
          >
            <view class="color-check" wx:if="{{themeColor === item.color}}">
              <text>✓</text>
            </view>
            <text class="color-name">{{item.name}}</text>
          </view>
        </block>
      </view>

      <view class="custom-color">
        <view class="custom-color-label">
          <text>自定义颜色</text>
        </view>
        <view class="custom-color-input">
          <input
            type="text"
            placeholder="#E8A87C"
            bindinput="onCustomColor"
            class="color-input"
            value="{{customColor}}"
          />
          <button class="apply-btn" style="background: {{themeColor}};" bindtap="applyCustomColor">
            <text>应用</text>
          </button>
        </view>
      </view>

      <view class="theme-close" bindtap="onCloseTheme">
        <text>完成</text>
      </view>
    </view>
  </view>
</view>
