<!-- 我的页面 -->
<view class="my-container">
  <!-- 用户信息卡片 -->
  <view class="user-card" style="background: linear-gradient(135deg, {{themeColor}} 0%, {{themeColorDark}} 100%);">
    <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '未登录'}}</text>
      <text class="status">{{isLoggedIn ? '已登录' : '点击登录'}}</text>
    </view>
    <button class="login-btn" bindtap="onLogin" wx:if="{{!isLoggedIn}}">登录</button>
    <button class="login-btn logout" bindtap="onLogout" wx:if="{{isLoggedIn}}">退出</button>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="onThemeChange">
      <text class="menu-icon">🎨</text>
      <text class="menu-text">主题颜色</text>
      <view class="color-preview" style="background: {{themeColor}};"></view>
      <text class="arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="arrow">></text>
    </view>
    
    <view class="menu-item">
      <text class="menu-icon">📋</text>
      <text class="menu-text">版本信息</text>
      <text class="menu-value">v1.0.0</text>
    </view>
  </view>

  <!-- 主题颜色选择弹窗 -->
  <view class="theme-modal" wx:if="{{showThemeModal}}">
    <view class="theme-mask" bindtap="onCloseTheme"></view>
    <view class="theme-content">
      <view class="theme-title">选择主题颜色</view>
      <view class="color-grid">
        <view 
          wx:for="{{colorOptions}}" 
          wx:key="index" 
          class="color-option {{themeColor === item.color ? 'active' : ''}}"
          style="background: {{item.color}};"
          bindtap="selectTheme" 
          data-color="{{item.color}}"
          data-colordark="{{item.colorDark}}"
        >
          <text wx:if="{{themeColor === item.color}}">✓</text>
        </view>
      </view>
      <view class="custom-color">
        <text>自定义颜色：</text>
        <input type="text" placeholder="#FF6B9D" bindinput="onCustomColor" class="color-input"/>
        <button size="mini" bindtap="applyCustomColor">应用</button>
      </view>
    </view>
  </view>
</view>
