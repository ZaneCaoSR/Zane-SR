<!-- 照片详情页 -->
<view class="photo-container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 照片主体 -->
  <block wx:if="{{!isLoading && photo}}">
    <!-- 大图区域 -->
    <view class="image-section" bindtap="previewImage">
      <image 
        src="{{photo.fileID}}" 
        mode="aspectFit" 
        class="main-image"
      />
      <!-- 里程碑标记 -->
      <view class="milestone-badge" wx:if="{{photo.isMilestone}}">
        <text>⭐ 里程碑</text>
      </view>
    </view>

    <!-- 信息区域 -->
    <view class="info-section">
      <!-- 拍摄时间 -->
      <view class="time-row">
        <text class="icon">📅</text>
        <text>{{formatDate(photo.shotDate || photo._createTime)}}</text>
      </view>

      <!-- AI 识别结果 -->
      <view class="ai-section" wx:if="{{photo.aiResult}}">
        <view class="section-title">
          <text class="icon">🤖</text>
          <text>AI 识别结果</text>
        </view>
        
        <!-- 表情标签 -->
        <view class="tag-group" wx:if="{{photo.aiResult.expressions && photo.aiResult.expressions.length > 0}}">
          <text class="group-label">表情:</text>
          <view class="tags">
            <block wx:for="{{photo.aiResult.expressions}}" wx:key="*this">
              <text class="tag expression">{{item}}</text>
            </block>
          </view>
        </view>

        <!-- 动作标签 -->
        <view class="tag-group" wx:if="{{photo.aiResult.actions && photo.aiResult.actions.length > 0}}">
          <text class="group-label">动作:</text>
          <view class="tags">
            <block wx:for="{{photo.aiResult.actions}}" wx:key="*this">
              <text class="tag action">{{item}}</text>
            </block>
          </view>
        </view>

        <!-- AI 描述 -->
        <view class="ai-description" wx:if="{{photo.aiResult.description}}">
          <text class="group-label">AI 描述:</text>
          <view class="description-content">
            <text>{{photo.aiResult.description}}</text>
            <text class="copy-btn" bindtap="copyDescription">复制</text>
          </view>
        </view>
      </view>

      <!-- 备注编辑 -->
      <view class="remark-section">
        <view class="section-title">
          <text class="icon">📝</text>
          <text>备注</text>
          <text class="edit-btn" bindtap="startEdit" wx:if="{{!isEditing}}">编辑</text>
        </view>
        
        <view class="remark-content" wx:if="{{!isEditing}}">
          <text wx:if="{{photo.remark}}">{{photo.remark}}</text>
          <text class="placeholder" wx:else>点击添加备注...</text>
        </view>
        
        <view class="remark-editor" wx:if="{{isEditing}}">
          <textarea 
            value="{{remark}}" 
            placeholder="添加备注..."
            bindinput="onRemarkInput"
            maxlength="200"
          />
          <view class="editor-actions">
            <button size="mini" bindtap="cancelEdit">取消</button>
            <button size="mini" type="primary" bindtap="saveRemark">保存</button>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-actions">
      <view class="action-btn" bindtap="toggleMilestone">
        <text>{{photo.isMilestone ? '⭐' : '☆'}}</text>
        <text>{{photo.isMilestone ? '取消标记' : '标记里程碑'}}</text>
      </view>
      <view class="action-btn delete" bindtap="showDeleteModal">
        <text>🗑️</text>
        <text>删除</text>
      </view>
    </view>
  </block>

  <!-- 删除确认弹窗 -->
  <view class="delete-modal" wx:if="{{showDeleteConfirm}}">
    <view class="modal-mask" bindtap="hideDeleteModal"></view>
    <view class="modal-content">
      <text class="modal-title">确认删除</text>
      <text class="modal-desc">删除后无法恢复，确定要删除这张照片吗？</text>
      <view class="modal-actions">
        <button bindtap="hideDeleteModal">取消</button>
        <button class="delete-btn" bindtap="deletePhoto">删除</button>
      </view>
    </view>
  </view>
</view>
