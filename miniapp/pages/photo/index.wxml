<!-- 照片详情页 -->
<view class="photo-container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 照片主体 -->
  <block wx:if="{{!isLoading && photo}}">
    <!-- 大图区域 -->
    <view class="image-section" bindtap="previewImage">
      <image 
        src="{{photo.fileID}}" 
        mode="aspectFit" 
        class="main-image"
      />
      <!-- 里程碑标记 -->
      <view class="milestone-badge" wx:if="{{photo.isMilestone}}">
        <text>⭐ 里程碑</text>
      </view>
    </view>

    <!-- 信息区域 -->
    <view class="info-section">
      <!-- 拍摄时间 -->
      <view class="time-row">
        <text class="icon">📅</text>
        <text>{{formatDate(photo.shotDate || photo._createTime)}}</text>
      </view>

      <!-- AI 识别结果 / 标签 -->
      <view class="ai-section">
        <view class="section-title">
          <text class="icon">🏷️</text>
          <text>标签</text>
          <text class="edit-btn" bindtap="analyzePhoto" wx:if="{{!photo.tags || photo.tags.length === 0}}">
            {{isAnalyzing ? '分析中...' : '+ AI 分析'}}
          </text>
          <text class="edit-btn" bindtap="showAddTagModal" wx:else>+ 添加</text>
        </view>

        <!-- 标签展示 -->
        <view class="tags-display" wx:if="{{photo.tags && photo.tags.length > 0}}">
          <view
            class="tag-item"
            wx:for="{{photo.tags}}"
            wx:key="index"
            style="background: {{getTagColor(item.type)}};"
          >
            <text class="tag-text">{{item.value}}</text>
            <text class="tag-remove" bindtap="removeTag" data-index="{{index}}">×</text>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="tags-empty" wx:if="{{!photo.tags || photo.tags.length === 0}}">
          <text>暂无标签，点击上方按钮添加</text>
        </view>
      </view>

      <!-- 备注编辑 -->
      <view class="remark-section">
        <view class="section-title">
          <text class="icon">📝</text>
          <text>备注</text>
          <text class="edit-btn" bindtap="startEdit" wx:if="{{!isEditing}}">编辑</text>
        </view>
        
        <view class="remark-content" wx:if="{{!isEditing}}">
          <text wx:if="{{photo.remark}}">{{photo.remark}}</text>
          <text class="placeholder" wx:else>点击添加备注...</text>
        </view>
        
        <view class="remark-editor" wx:if="{{isEditing}}">
          <textarea 
            value="{{remark}}" 
            placeholder="添加备注..."
            bindinput="onRemarkInput"
            maxlength="200"
          />
          <view class="editor-actions">
            <button size="mini" bindtap="cancelEdit">取消</button>
            <button size="mini" type="primary" bindtap="saveRemark">保存</button>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-actions">
      <view class="action-btn" bindtap="toggleMilestone">
        <text>{{photo.isMilestone ? '⭐' : '☆'}}</text>
        <text>{{photo.isMilestone ? '取消标记' : '标记里程碑'}}</text>
      </view>
      <view class="action-btn delete" bindtap="showDeleteModal">
        <text>🗑️</text>
        <text>删除</text>
      </view>
    </view>
  </block>

  <!-- 删除确认弹窗 -->
  <view class="delete-modal" wx:if="{{showDeleteConfirm}}">
    <view class="modal-mask" bindtap="hideDeleteModal"></view>
    <view class="modal-content">
      <text class="modal-title">确认删除</text>
      <text class="modal-desc">删除后无法恢复，确定要删除这张照片吗？</text>
      <view class="modal-actions">
        <button bindtap="hideDeleteModal">取消</button>
        <button class="delete-btn" bindtap="deletePhoto">删除</button>
      </view>
    </view>
  </view>

  <!-- 添加标签弹窗 -->
  <view class="tag-modal" wx:if="{{showTagModal}}">
    <view class="modal-mask" bindtap="hideTagModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">添加标签</text>
        <text class="modal-close" bindtap="hideTagModal">×</text>
      </view>

      <picker range="{{tagTypes}}" range-key="label" bindchange="onTagTypeChange">
        <view class="picker-selected">
          <text>类型: {{tagTypes[newTag.type === 'emotion' ? 0 : newTag.type === 'action' ? 1 : newTag.type === 'milestone' ? 2 : newTag.type === 'scene' ? 3 : 4].label}}</text>
        </view>
      </picker>

      <view class="tag-values">
        <view
          class="tag-value-item"
          wx:for="{{tagTypes[newTag.type === 'emotion' ? 0 : newTag.type === 'action' ? 1 : newTag.type === 'milestone' ? 2 : newTag.type === 'scene' ? 3 : 4].values}}"
          wx:key="*this"
          bindtap="onTagValueTap"
          data-value="{{item}}"
        >
          <text>{{item}}</text>
        </view>
      </view>

      <view class="custom-tag">
        <input
          class="custom-input"
          placeholder="或输入自定义标签"
          value="{{newTag.value}}"
          bindinput="onCustomTagInput"
        />
        <button size="mini" type="primary" bindtap="addTag">添加</button>
      </view>
    </view>
  </view>
</view>
