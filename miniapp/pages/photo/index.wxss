/* 照片详情页样式 - 奶油日记风格 */

.photo-container {
  min-height: 100vh;
  background: #1a1a1a;
  padding-bottom: 140rpx;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: #fff;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--spacing-md);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 图片区域 */
.image-section {
  position: relative;
  width: 100%;
  height: 60vh;
  background: #000;
}

.main-image {
  width: 100%;
  height: 100%;
}

.milestone-badge {
  position: absolute;
  top: var(--spacing-lg);
  right: var(--spacing-lg);
  background: linear-gradient(135deg, #E8C07D 0%, #D4A968 100%);
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(232, 192, 125, 0.4);
}

/* 信息区域 */
.info-section {
  background: var(--color-surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--spacing-xl);
  margin-top: -32rpx;
  position: relative;
  z-index: 1;
}

.time-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-lg);
}

.time-row .icon {
  font-size: 32rpx;
}

/* AI 识别结果 */
.ai-section {
  margin-bottom: var(--spacing-lg);
  padding-bottom: var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-bg-secondary);
}

.section-title {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-family: var(--font-family-display);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

.section-title .icon {
  font-size: 36rpx;
}

.edit-btn {
  margin-left: auto;
  font-size: 26rpx;
  color: var(--color-accent);
  font-weight: normal;
}

.tag-group {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--spacing-sm);
}

.group-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  width: 100rpx;
  flex-shrink: 0;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  flex: 1;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: #fff;
}

.tag.expression {
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
}

.tag.action {
  background: linear-gradient(135deg, #95B8A0 0%, #7BA085 100%);
}

.ai-description {
  margin-top: var(--spacing-md);
}

.description-content {
  display: flex;
  align-items: flex-start;
  background: var(--color-bg-secondary);
  padding: var(--spacing-md);
  border-radius: var(--radius-lg);
  margin-top: var(--spacing-xs);
}

.description-content text:first-child {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.copy-btn {
  font-size: 24rpx;
  color: var(--color-accent);
  margin-left: var(--spacing-md);
  flex-shrink: 0;
}

/* 备注区域 */
.remark-section {
  margin-top: var(--spacing-md);
}

.remark-content {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  padding: var(--spacing-md);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
}

.remark-content .placeholder {
  color: var(--color-text-tertiary);
}

.remark-editor textarea {
  width: 100%;
  height: 150rpx;
  padding: var(--spacing-md);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  box-sizing: border-box;
  color: var(--color-text-primary);
}

.editor-actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--spacing-md);
  margin-top: var(--spacing-md);
}

.editor-actions button {
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  border-radius: var(--radius-full);
  border: none;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--spacing-lg);
  padding: var(--spacing-lg);
  padding-bottom: calc(var(--spacing-lg) + env(safe-area-inset-bottom));
  background: var(--color-surface);
  box-shadow: 0 -8rpx 24rpx rgba(74, 64, 58, 0.08);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-md);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-primary);
  transition: all var(--duration-normal);
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn.delete {
  color: var(--color-error);
}

.action-btn text:first-child {
  font-size: 36rpx;
}

/* 删除确认弹窗 */
.delete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(74, 64, 58, 0.4);
  backdrop-filter: blur(8rpx);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  text-align: center;
}

.modal-title {
  display: block;
  font-family: var(--font-family-display);
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xl);
}

.modal-actions {
  display: flex;
  gap: var(--spacing-lg);
}

.modal-actions button {
  flex: 1;
  padding: var(--spacing-md);
  border-radius: var(--radius-full);
  font-size: 30rpx;
  border: none;
  background: var(--color-bg-secondary);
  color: var(--color-text-secondary);
}

.modal-actions .delete-btn {
  background: linear-gradient(135deg, var(--color-error) 0%, #c06c6c 100%);
  color: #fff;
}
