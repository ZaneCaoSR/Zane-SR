/* 照片详情页样式 */

.photo-container {
  min-height: 100vh;
  background: #1a1a1a;
  padding-bottom: 140rpx;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: #fff;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #FF6B9D;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 图片区域 */
.image-section {
  position: relative;
  width: 100%;
  height: 60vh;
  background: #000;
}

.main-image {
  width: 100%;
  height: 100%;
}

.milestone-badge {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: linear-gradient(135deg, #FFB347 0%, #FF9500 100%);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(255, 179, 71, 0.5);
}

/* 信息区域 */
.info-section {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  margin-top: -32rpx;
  position: relative;
  z-index: 1;
}

.time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.time-row .icon {
  font-size: 32rpx;
}

/* AI 识别结果 */
.ai-section {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-title .icon {
  font-size: 36rpx;
}

.edit-btn {
  margin-left: auto;
  font-size: 26rpx;
  color: #FF6B9D;
  font-weight: normal;
}

.tag-group {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.group-label {
  font-size: 26rpx;
  color: #666;
  width: 100rpx;
  flex-shrink: 0;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.tag.expression {
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
}

.tag.action {
  background: linear-gradient(135deg, #67D4CA 0%, #4ECDC4 100%);
}

.ai-description {
  margin-top: 20rpx;
}

.description-content {
  display: flex;
  align-items: flex-start;
  background: #f8f8f8;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-top: 12rpx;
}

.description-content text:first-child {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.copy-btn {
  font-size: 24rpx;
  color: #FF6B9D;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 备注区域 */
.remark-section {
  margin-top: 20rpx;
}

.remark-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.remark-content .placeholder {
  color: #999;
}

.remark-editor textarea {
  width: 100%;
  height: 150rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.editor-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
}

.editor-actions button {
  padding: 16rpx 40rpx;
  font-size: 26rpx;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 30rpx;
  padding: 30rpx 40rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.action-btn.delete {
  color: #ff4d4f;
}

.action-btn text:first-child {
  font-size: 36rpx;
}

/* 删除确认弹窗 */
.delete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 30rpx;
}

.modal-actions button {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  border: none;
  background: #f0f0f0;
  color: #666;
}

.modal-actions .delete-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #ff4d4f 100%);
  color: #fff;
}
