/* 宝宝信息设置页样式 - 奶油日记风格 */

.settings-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 200rpx;
}

/* 头部 */
.header {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx var(--spacing-lg) var(--spacing-xl);
  background: linear-gradient(165deg, #FFF8F0 0%, #FFE8D6 100%);
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle at 20% 30%, rgba(232, 168, 124, 0.15) 0%, transparent 50%),
                    radial-gradient(circle at 80% 70%, rgba(149, 184, 160, 0.15) 0%, transparent 50%);
}

.avatar-section {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  z-index: 1;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid var(--color-surface);
  box-shadow: var(--shadow-lg);
  background: var(--color-bg-secondary);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  background: var(--color-accent);
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
}

.baby-age {
  position: relative;
  z-index: 1;
  margin-top: var(--spacing-md);
  background: rgba(232, 168, 124, 0.2);
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
}

.baby-age text {
  color: var(--color-accent-dark);
  font-size: 26rpx;
  font-weight: 500;
}

/* 表单区域 */
.form-section {
  background: var(--color-surface);
  margin: var(--spacing-lg);
  border-radius: var(--radius-xl);
  padding: var(--spacing-sm) 0;
  box-shadow: var(--shadow-md);
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg) var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-bg-secondary);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-left: var(--spacing-lg);
}

.form-picker {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.form-picker text {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.form-picker .placeholder {
  color: var(--color-text-tertiary);
}

.form-picker .arrow {
  color: var(--color-text-tertiary);
  font-size: 36rpx;
}

/* 性别选择 */
.gender-select {
  display: flex;
  gap: var(--spacing-md);
}

.gender-btn {
  padding: 16rpx 32rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-secondary);
  font-size: 28rpx;
  color: var(--color-text-secondary);
  transition: all var(--duration-normal);
}

.gender-btn.active {
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(232, 168, 124, 0.3);
}

/* 隐私设置 */
.privacy-section {
  background: var(--color-surface);
  margin: var(--spacing-lg);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-md);
}

.section-title {
  font-family: var(--font-family-display);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

.privacy-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-bg-secondary);
}

.privacy-item:last-child {
  border-bottom: none;
}

.privacy-info {
  display: flex;
  flex-direction: column;
}

.privacy-label {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.privacy-desc {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

/* 底部保存按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  background: var(--color-surface);
  box-shadow: 0 -8rpx 24rpx rgba(74, 64, 58, 0.08);
}

.save-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: var(--radius-full);
  font-size: 32rpx;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(232, 168, 124, 0.3);
}

/* 日期选择器 */
.date-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(74, 64, 58, 0.4);
  backdrop-filter: blur(8rpx);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-bg-secondary);
}

.picker-header text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.picker-header .confirm {
  color: var(--color-accent);
  font-weight: 600;
}

picker-view {
  height: 400rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-primary);
}
