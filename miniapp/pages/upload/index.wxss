/* 上传页面样式 */

.upload-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F8 0%, #FFF0F5 100%);
  padding: 30rpx;
  padding-bottom: 200rpx;
}

/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.4;
}

.step.active {
  opacity: 1;
}

.step-num {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e0e0e0;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.step.active .step-num {
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
  color: #fff;
}

.step text {
  font-size: 24rpx;
  color: #999;
}

.step.active text {
  color: #FF6B9D;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e0e0e0;
  margin: 0 10rpx;
  margin-bottom: 40rpx;
}

.step-line.active {
  background: linear-gradient(90deg, #FF9ECA 0%, #FF6B9D 100%);
}

/* 预览区 */
.preview-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.preview-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.preview-scroll {
  width: 100%;
}

.preview-list {
  display: flex;
  gap: 20rpx;
}

.preview-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.preview-item image {
  width: 100%;
  height: 100%;
}

.preview-status {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.uploading-icon {
  font-size: 60rpx;
}

.add-more {
  width: 200rpx;
  height: 200rpx;
  border: 4rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  flex-shrink: 0;
}

.add-more text:first-child {
  font-size: 60rpx;
  line-height: 1;
}

.add-more text:last-child {
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* 空选择状态 */
.empty-select {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-select .empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-select text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.select-btns {
  display: flex;
  gap: 30rpx;
}

.select-btns button {
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
  color: #fff;
  border: none;
}

/* 进度条 */
.progress-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9ECA 0%, #FF6B9D 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-fill.analyze {
  background: linear-gradient(90deg, #67D4CA 0%, #4ECDC4 100%);
}

.ai-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.analyze-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

/* 完成状态 */
.complete-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.complete-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.complete-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.complete-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.complete-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.complete-actions button {
  width: 100%;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
  color: #fff;
  border: none;
}

.complete-actions button.secondary {
  background: #fff;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.upload-btn {
  width: 100%;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  background: linear-gradient(135deg, #FF9ECA 0%, #FF6B9D 100%);
  color: #fff;
  border: none;
}

.upload-btn[disabled] {
  background: #ccc;
}
