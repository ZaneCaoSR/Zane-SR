/* 上传页面样式 - 奶油日记风格 */

.upload-container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-secondary) 100%);
  padding: var(--spacing-md);
  padding-bottom: 200rpx;
}

/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-md);
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.4;
}

.step.active {
  opacity: 1;
}

.step-num {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--color-bg-secondary);
  color: var(--color-text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: var(--spacing-xs);
  transition: all var(--duration-normal);
}

.step.active .step-num {
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(232, 168, 124, 0.4);
}

.step text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.step.active text {
  color: var(--color-accent);
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: var(--color-bg-secondary);
  margin: 0 var(--spacing-sm);
  margin-bottom: 40rpx;
  border-radius: 2rpx;
}

.step-line.active {
  background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
}

/* 预览区 */
.preview-section {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-md);
}

.preview-title {
  font-family: var(--font-family-display);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

.preview-scroll {
  width: 100%;
}

.preview-list {
  display: flex;
  gap: var(--spacing-md);
}

.preview-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.preview-item image {
  width: 100%;
  height: 100%;
}

.preview-status {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(74, 64, 58, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.uploading-icon {
  font-size: 60rpx;
}

.add-more {
  width: 200rpx;
  height: 200rpx;
  border: 4rpx dashed var(--color-text-tertiary);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  transition: all var(--duration-normal);
}

.add-more:active {
  border-color: var(--color-accent);
  background: var(--color-bg-secondary);
}

.add-more text:first-child {
  font-size: 60rpx;
  line-height: 1;
}

.add-more text:last-child {
  font-size: 24rpx;
  margin-top: var(--spacing-xs);
}

/* 空选择状态 */
.empty-select {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-lg);
}

.empty-select .empty-icon {
  font-size: 140rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-select text {
  color: var(--color-text-tertiary);
  font-size: 28rpx;
  margin-bottom: var(--spacing-xl);
}

.select-btns {
  display: flex;
  gap: var(--spacing-lg);
}

.select-btns button {
  padding: 24rpx 48rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(232, 168, 124, 0.3);
}

/* 进度条 */
.progress-section {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  text-align: center;
  box-shadow: var(--shadow-md);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
}

.progress-bar {
  height: 16rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.progress-fill.analyze {
  background: linear-gradient(90deg, #95B8A0 0%, #7BA085 100%);
}

.ai-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-md);
}

.analyze-text {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-lg);
}

/* 完成状态 */
.complete-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-lg);
}

.complete-icon {
  font-size: 140rpx;
  margin-bottom: var(--spacing-lg);
  animation: bounceIn 0.6s var(--ease-out-back);
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.5);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.complete-title {
  font-family: var(--font-family-display);
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.complete-desc {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  margin-bottom: var(--spacing-xl);
}

.complete-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
  width: 100%;
}

.complete-actions button {
  width: 100%;
  padding: 28rpx;
  border-radius: var(--radius-full);
  font-size: 32rpx;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(232, 168, 124, 0.3);
}

.complete-actions button.secondary {
  background: var(--color-surface);
  color: var(--color-accent);
  border: 2rpx solid var(--color-accent);
  box-shadow: none;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  background: var(--color-surface);
  box-shadow: 0 -8rpx 24rpx rgba(74, 64, 58, 0.08);
}

.upload-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: var(--radius-full);
  font-size: 32rpx;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(232, 168, 124, 0.3);
}

.upload-btn[disabled] {
  background: var(--color-text-tertiary);
  box-shadow: none;
}
