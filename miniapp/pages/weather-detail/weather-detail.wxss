/* weather-detail.wxss - 天气详情页面样式 */

.container {
  min-height: 100vh;
  background: #F0F6FF;
  padding-bottom: 180rpx;
}

/* 顶部天气卡片 */
.weather-header {
  background: linear-gradient(135deg, #4A90D9, #7EC8E3);
  padding: 60rpx 40rpx;
  color: #fff;
  text-align: center;
}

.city-name {
  font-size: 36rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.weather-temp {
  font-size: 140rpx;
  font-weight: 200;
  line-height: 1;
  margin: 20rpx 0;
}

.weather-desc {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.weather-range {
  font-size: 28rpx;
  opacity: 0.8;
}

.update-time {
  font-size: 22rpx;
  opacity: 0.6;
  margin-top: 16rpx;
}

/* 详细数据卡片 */
.detail-card, .aqi-card, .hourly-card, .forecast-card, .life-card {
  background: #fff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.detail-title, .aqi-title, .hourly-title, .forecast-title, .life-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
}

.detail-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-top: 6rpx;
}

/* 空气质量 */
.aqi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.aqi-level {
  font-size: 26rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background: #e6f7e6;
  color: #52c41a;
}

.aqi-level.level-2 {
  background: #fff7e6;
  color: #faad14;
}

.aqi-level.level-3 {
  background: #fff1f0;
  color: #ff4d4f;
}

.aqi-level.level-4, .aqi-level.level-5 {
  background: #f5f5f5;
  color: #999;
}

.aqi-values {
  display: flex;
  justify-content: space-around;
}

.aqi-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.aqi-label {
  font-size: 24rpx;
  color: #999;
}

.aqi-num {
  font-size: 40rpx;
  font-weight: 500;
  color: #333;
  margin-top: 8rpx;
}

/* 小时预报 */
.hourly-scroll {
  width: 100%;
  white-space: nowrap;
}

.hourly-list {
  display: flex;
}

.hourly-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  min-width: 100rpx;
}

.hourly-time {
  font-size: 24rpx;
  color: #999;
}

.hourly-icon {
  font-size: 48rpx;
  margin: 10rpx 0;
}

.hourly-temp {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 日预报 */
.forecast-list {
  display: flex;
  flex-direction: column;
}

.forecast-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.forecast-item:last-child {
  border-bottom: none;
}

.forecast-date {
  width: 100rpx;
  font-size: 28rpx;
  color: #666;
}

.forecast-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.forecast-desc {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.forecast-temp {
  font-size: 28rpx;
  color: #666;
}

/* 生活指数 */
.life-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.life-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.life-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.life-type {
  font-size: 24rpx;
  color: #999;
}

.life-value {
  font-size: 26rpx;
  color: #333;
  margin-top: 6rpx;
}

/* 底部订阅栏 */
.subscribe-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.subscribe-btn {
  width: 100%;
  background: linear-gradient(135deg, #4A90D9, #7EC8E3);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.subscribed-status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.subscribed-text {
  font-size: 28rpx;
  color: #4A90D9;
}

.unsub-btn {
  background: #f5f5f5;
  color: #999;
  font-size: 26rpx;
}

/* 加载中 */
.loading-box {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}
