/* 天气首页样式 */
.weather-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4A90E2 0%, #67B8DE 100%);
  padding: 20px;
}

.city-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 20px;
  background: rgba(255,255,255,0.2);
  border-radius: 10px;
  margin-bottom: 30px;
}

.city-name {
  font-size: 24px;
  color: #fff;
  font-weight: bold;
}

.city-change {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
}

.weather-card {
  text-align: center;
  padding: 40px 20px;
  background: rgba(255,255,255,0.95);
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  margin-bottom: 20px;
}

.temp {
  font-size: 80px;
  color: #333;
  font-weight: 200;
  line-height: 1;
}

.weather-desc {
  font-size: 20px;
  color: #666;
  margin-top: 10px;
}

.update-time {
  font-size: 12px;
  color: #999;
  margin-top: 15px;
}

.detail-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  background: rgba(255,255,255,0.95);
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 20px;
}

.detail-item {
  width: 45%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15px 0;
}

.detail-item .label {
  font-size: 12px;
  color: #999;
}

.detail-item .value {
  font-size: 18px;
  color: #333;
  font-weight: bold;
  margin-top: 5px;
}

.subscribe-btn {
  width: 100%;
  background: #FF6B9D;
  color: #fff;
  border-radius: 30px;
  padding: 15px 0;
  font-size: 16px;
  border: none;
}

.subscribe-btn:active {
  opacity: 0.8;
}
