/* 天气首页样式 - 奶油日记风格 */

/* 页面进入动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.weather-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: var(--spacing-md);
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.5s ease-out;
}

/* 卡片渐入 */
.weather-hero,
.detail-grid,
.forecast-section,
.hourly-section,
.air-section,
.indices-section,
.sun-section,
.temp-chart-section,
.tips-section {
  animation: fadeInUp 0.5s ease-out;
  animation-fill-mode: both;
}

.weather-hero { animation-delay: 0.1s; }
.detail-grid { animation-delay: 0.2s; }
.forecast-section { animation-delay: 0.3s; }
.hourly-section { animation-delay: 0.35s; }
.air-section { animation-delay: 0.4s; }
.indices-section { animation-delay: 0.45s; }
.sun-section { animation-delay: 0.5s; }
.temp-chart-section { animation-delay: 0.55s; }
.tips-section { animation-delay: 0.15s; }

/* 加载骨架屏动画 */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 天气提示 */
.tips-section {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.tip-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 天气预警 */
.alert-section {
  margin-bottom: var(--spacing-md);
}

.alert-item {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
  padding: var(--spacing-md);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-sm);
}

.alert-item.orange {
  background: #fff7e6;
  border-left: 6rpx solid #fa8c16;
}

.alert-item.red {
  background: #fff1f0;
  border-left: 6rpx solid #f5222d;
}

.alert-item.yellow {
  background: #fffff0;
  border-left: 6rpx solid #fadb14;
}

.alert-item.blue {
  background: #e6f7ff;
  border-left: 6rpx solid #1890ff;
}

.alert-item.other {
  background: #fafafa;
  border-left: 6rpx solid #8c8c8c;
}

.alert-icon {
  font-size: 32rpx;
}

.alert-content {
  flex: 1;
}

.alert-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #d46b08;
  margin-bottom: var(--spacing-xs);
}

.alert-item.red .alert-title {
  color: #cf1322;
}

.alert-item.blue .alert-title {
  color: #096dd9;
}

.alert-text {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
  line-height: 1.5;
}

/* Swiper 容器 */
.weather-swiper {
  height: 720rpx;
}

.weather-slide {
  height: 100%;
  padding: 0 var(--spacing-xs);
}

/* 城市指示器 */
.city-indicator {
  position: absolute;
  top: 180rpx;
  right: var(--spacing-lg);
  z-index: 100;
  background: rgba(0, 0, 0, 0.2);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-lg);
}

.indicator-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

/* 顶部城市栏 */
.city-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-lg);
  position: relative;
  z-index: 10;
}

.city-info {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.city-icon {
  font-size: 28rpx;
}

.city-name {
  font-family: var(--font-family-display);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.city-action {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.city-meta {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.push-time {
  font-size: 22rpx;
  color: var(--color-accent);
  background: rgba(232, 168, 124, 0.15);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-lg);
}

.city-action-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.city-action .arrow {
  transition: transform var(--duration-normal);
}

/* 天气主卡片 */
.weather-hero {
  position: relative;
  background: linear-gradient(165deg, #FFF8F0 0%, #FFEFDF 50%, #FFE8D6 100%);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl) var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  overflow: hidden;
  min-height: 380rpx;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 209, 102, 0.4) 0%, transparent 70%);
  top: -60rpx;
  right: -40rpx;
  animation: float 6s ease-in-out infinite;
}

.circle-2 {
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(232, 168, 124, 0.3) 0%, transparent 70%);
  bottom: -40rpx;
  left: -30rpx;
  animation: float 8s ease-in-out infinite reverse;
}

.circle-3 {
  width: 100rpx;
  height: 100rpx;
  background: radial-gradient(circle, rgba(149, 184, 160, 0.3) 0%, transparent 70%);
  top: 40%;
  left: 30%;
  animation: float 7s ease-in-out infinite 1s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) scale(1);
  }
  50% {
    transform: translateY(-20rpx) scale(1.05);
  }
}

/* 天气主题背景 */
.theme-sunny .weather-hero {
  background: linear-gradient(165deg, #FFF8F0 0%, #FFEFDF 50%, #FFE8D6 100%);
}

.theme-cloudy .weather-hero {
  background: linear-gradient(165deg, #F0F4F8 0%, #D9E2EC 50%, #BCCCDC 100%);
}

.theme-rainy .weather-hero {
  background: linear-gradient(165deg, #E8F4F8 0%, #D0E8F0 50%, #B8D8E8 100%);
}

.theme-snowy .weather-hero {
  background: linear-gradient(165deg, #F5F8FF 0%, #E8EEF8 50%, #D8E4F5 100%);
}

.theme-foggy .weather-hero {
  background: linear-gradient(165deg, #F0F0F0 0%, #E8E8E8 50%, #D8D8D8 100%);
}

.theme-stormy .weather-hero {
  background: linear-gradient(165deg, #4A4A5A 0%, #3A3A4A 50%, #2A2A3A 100%);
}

.theme-stormy .temp-value,
.theme-stormy .weather-desc {
  color: #fff;
}

.theme-stormy .feels-like,
.theme-stormy .temp-unit {
  color: rgba(255, 255, 255, 0.7);
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg) 0;
}

/* 天气图标 */
.weather-icon-wrapper {
  margin-bottom: var(--spacing-md);
}

.weather-icon-large {
  font-size: 120rpx;
  line-height: 1;
  display: block;
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.1));
  animation: iconBounce 3s ease-in-out infinite;
}

@keyframes iconBounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

/* 温度显示 */
.temp-display {
  display: flex;
  align-items: flex-start;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.temp-value {
  font-family: var(--font-family-display);
  font-size: 140rpx;
  font-weight: 300;
  line-height: 1;
  letter-spacing: -8rpx;
}

.temp-unit {
  font-family: var(--font-family-display);
  font-size: 48rpx;
  font-weight: 300;
  margin-top: 20rpx;
  color: var(--color-text-secondary);
}

/* 天气文字 */
.weather-text {
  text-align: center;
}

.weather-desc {
  display: block;
  font-size: 36rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  margin-bottom: var(--spacing-xs);
}

.feels-like {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* 舒适度 */
.comfort-level {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-md);
  background: rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-xl);
}

.comfort-icon {
  font-size: 32rpx;
}

.comfort-text {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.comfort-bar {
  flex: 1;
  height: 8rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.comfort-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6b6b, #feca57, #48dbfb);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 今日温度范围 */
.temp-range {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-sm);
}

.temp-low {
  font-size: 28rpx;
  color: #74b9ff;
  font-weight: 500;
}

.temp-high {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: 500;
}

.temp-divider {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* 详情网格 */
.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.detail-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal) var(--ease-out-expo);
  position: relative;
  overflow: hidden;
}

.detail-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-accent-light), var(--color-accent));
}

.detail-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.detail-icon {
  font-size: 40rpx;
  margin-bottom: var(--spacing-xs);
}

.detail-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: var(--spacing-xs);
}

.detail-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 日出日落 */
.sun-section {
  display: flex;
  justify-content: space-around;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.sun-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}

.sun-icon {
  font-size: 40rpx;
}

.sun-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.sun-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

/* 空气质量 */
.air-section {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.air-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.air-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.air-aqi {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.air-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.air-category {
  font-size: 32rpx;
  font-weight: 600;
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-md);
}

.air-category.优 {
  background: #e6f7e6;
  color: #52c41a;
}

.air-category.良 {
  background: #f6ffed;
  color: #1890ff;
}

.air-category.轻度 {
  background: #fff7e6;
  color: #faad14;
}

.air-category.中度 {
  background: #fff1f0;
  color: #fa541c;
}

.air-category.重度 {
  background: #fff2f0;
  color: #f5222d;
}

.air-category.严重 {
  background: #fff0f0;
  color: #a8071a;
}

.air-detail {
  display: flex;
  gap: var(--spacing-md);
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 温度曲线 */
.temp-chart-section {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.temp-chart-header {
  margin-bottom: var(--spacing-md);
}

.temp-chart-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.temp-chart {
  height: 200rpx;
}

.temp-chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 160rpx;
  padding: 0 var(--spacing-sm);
}

.temp-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.temp-bar {
  width: 16rpx;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 10rpx;
}

.temp-bar.warm {
  background: linear-gradient(to top, #ff9a56, #ff6b6b);
}

.temp-bar.cool {
  background: linear-gradient(to top, #74b9ff, #0984e3);
}

.temp-bar-label {
  font-size: 18rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

/* 逐小时预报 */
.hourly-section {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.hourly-header {
  margin-bottom: var(--spacing-sm);
}

.hourly-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.hourly-scroll {
  width: 100%;
  white-space: nowrap;
}

.hourly-list {
  display: flex;
  gap: var(--spacing-md);
}

.hourly-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  min-width: 100rpx;
  padding: var(--spacing-sm);
  background: var(--color-bg);
  border-radius: var(--radius-md);
}

.hourly-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.hourly-temp {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.hourly-weather {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.hourly-pop {
  font-size: 20rpx;
  color: #1890ff;
}

/* 更新时间 */
.update-info {
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.update-text {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.5rpx;
}

/* 订阅按钮 */
.action-area {
  padding: 0 var(--spacing-md);
}

.btn-subscribe {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: 32rpx;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
  color: white;
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 12rpx 32rpx rgba(232, 168, 124, 0.4);
  border: none;
  position: relative;
  overflow: hidden;
}

.btn-subscribe::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.btn-subscribe:active::before {
  left: 100%;
}

.btn-icon {
  font-size: 32rpx;
}

/* 分享按钮 */
.btn-share {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: 32rpx;
  background: var(--color-surface);
  color: var(--color-text-primary);
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: var(--shadow-sm);
  border: none;
  margin-top: var(--spacing-md);
}

/* 城市加载中 */
.city-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
}

.city-loading text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 3日预报 */
.forecast-section {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.forecast-header {
  margin-bottom: var(--spacing-sm);
}

.forecast-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.forecast-list {
  display: flex;
  justify-content: space-between;
}

.forecast-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  flex: 1;
}

.forecast-date {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.forecast-weather {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.forecast-temp {
  font-size: 24rpx;
  color: var(--color-accent);
  font-weight: 500;
}

/* 生活指数 */
.indices-section {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.indices-header {
  margin-bottom: var(--spacing-sm);
}

.indices-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.indices-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-sm);
}

.indices-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-sm);
  background: var(--color-bg);
  border-radius: var(--radius-md);
}

.indices-icon {
  font-size: 32rpx;
}

.indices-label {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

.indices-value {
  font-size: 22rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  text-align: center;
}
